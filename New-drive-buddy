    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body { 
      font-family: 'Inter', sans-serif; 
      background: var(--night); 
      color: var(--platinum); 
      overflow-x: hidden;
      position: relative;
