    /* FIXED SELECT VISIBILITY */
    select option {
      background: #1a1f2e !important;
      color: #f8fafc !important;
      font-size: 1rem !important;
    }

    /* PARTICLES */
    .particles {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
      pointer-events: none; z-index: -1;
    }
    .particle {
      position: absolute; width: 4px; height: 4px; 
      background: var(--blue-glow); border-radius: 50%;
      animation: float 20s infinite linear;
    }
    .particle:nth-child(odd) { background: var(--gold-glow); animation-duration: 25s; }
    @keyframes float {
      0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { transform: translateY(-100px) rotate(360deg); opacity: 0; }
    }

    .gradient-bg {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2;
      background: 
        radial-gradient(circle at 20% 30%, rgba(59,130,246,0.15) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(250,204,21,0.12) 0%, transparent 50%),
        linear-gradient(135deg, var(--night) 0%, var(--slate) 100%);
      animation: gradientShift 15s ease infinite;
    }
    @keyframes gradientShift {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }

    /* NAVBAR */
    .navbar {
      position: fixed; top: 0; width: 100%; padding: 1.5rem 5%;
      background: rgba(10,14,23,0.95); backdrop-filter: blur(40px);
      border-bottom: 1px solid var(--glass-border); z-index: 1000;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
