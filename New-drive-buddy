      --slate: #1a1f2e;
      --platinum: #f8fafc;
      --silver: #e2e8f0;
      --blue-glow: #3b82f6;
      --gold-glow: #facc15;
      --glass: rgba(255,255,255,0.08);
      --glass-border: rgba(255,255,255,0.12);
