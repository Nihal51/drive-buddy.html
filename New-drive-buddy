      background: linear-gradient(135deg, var(--platinum), var(--silver));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .nav-links {
      display: flex; gap: 3rem; list-style: none; align-items: center;
    }
    .nav-links a {
      color: var(--platinum); text-decoration: none; font-weight: 600;
      position: relative; transition: all 0.3s ease;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -5px; left: 0;
      width: 0; height: 2px; background: var(--blue-glow);
      transition: width 0.3s ease;
    }
    .nav-links a:hover::after { width: 100%; }
    .nav-links a:hover { color: var(--blue-glow); }

